# Supabase (required for DB + storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NewsAPI.org — 32-character hex key from https://newsapi.org/account (Register → API key).
# Not a UUID. Same key can live in mini-apps-dashboard/.env.local when using dev:all.
# Free tier: /v2/everything localhost-only; see https://newsapi.org/pricing
#
# Precedence: in development, the first `NEWS_API_KEY` in `.env.local` (on disk) wins over
# stale `process.env` from when `next dev` started. In production, host/Vercel env wins,
# then file fallback. Use one active `NEWS_API_KEY=...` line (comment old keys).
#
# On NewsAPI 429, falls back to Google News RSS (no key). Disable: NEWS_RSS_FALLBACK=0
# NEWS_API_CACHE_MS=600000   # identical /everything cache (0 = off)
# NEWS_API_COOLDOWN_MS=...   # skip NewsAPI after 429 (0 = off; default 20 min)
NEWS_API_KEY=

# OpenAI (required for summarization)
OPENAI_API_KEY=sk-...
# Optional: summarization timeout ms (default 90000)
# OPENAI_SUMMARIZE_TIMEOUT_MS=90000

# ElevenLabs — key must allow Text to speech (edit key → Restrictions, or use unrestricted key)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-api-key
# Optional: EU/IN residency host if ElevenLabs told you to use it
# ELEVENLABS_API_BASE_URL=https://api.eu.residency.elevenlabs.io
# Voice ID from Voices (optional; app picks first premade voice if unset)
# ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# Dual-host dialogue: Akshay (male) / Kriti (female) — legacy ALEX/JAMIE still work
# ELEVENLABS_VOICE_AKSHAY=...
# ELEVENLABS_VOICE_KRITI=...
# ELEVENLABS_VOICE_ALEX=...  # fallback if AKSHAY unset
# ELEVENLABS_VOICE_JAMIE=... # fallback if KRITI unset

# Microsoft Azure AI Speech (secondary when ElevenLabs is primary, or primary when user picks Azure)
# Create a Speech resource in Azure Portal → Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# Optional default neural voice (single-voice / long scripts)
# AZURE_SPEECH_VOICE=en-US-JennyNeural
# Dialogue hosts (dual-voice TTS); defaults Guy / Jenny if unset
# AZURE_SPEECH_VOICE_MALE=en-US-GuyNeural
# AZURE_SPEECH_VOICE_FEMALE=en-US-JennyNeural

# OpenAI TTS per dialogue host (optional; legacy ALEX/JAMIE still work)
# OPENAI_TTS_VOICE_AKSHAY=onyx
# OPENAI_TTS_VOICE_KRITI=nova

# Set to true to skip Jina Reader (URLs won’t be sent to r.jina.ai)
# EXTRACT_DISABLE_JINA=true
# Mercury parser wall-clock timeout ms (avoids stuck “Extracting…” on slow hosts; default 22000)
# EXTRACT_MERCURY_TIMEOUT_MS=22000
# Max time per URL (Jina+fetch parallel + Mercury fallback; default 85000)
# EXTRACT_PER_URL_TIMEOUT_MS=85000
# Max wait to read Jina Reader response body (default 28000)
# EXTRACT_JINA_BODY_TIMEOUT_MS=28000
# Max wait to read HTML response body (default 22000)
# EXTRACT_FETCH_BODY_TIMEOUT_MS=22000
# Cap HTML before JSDOM/Readability (default 450000) — huge pages freeze Node and stall progress
# EXTRACT_MAX_HTML_CHARS=450000
# HTML parse runs in a child process by default (keeps % progress updating). Disable if deploy blocks spawn:
# EXTRACT_SYNC_PARSE=true
# EXTRACT_HTML_WORKER_MS=22000
# Full URL extract in one child process (max isolation if still stuck at 9%; heavier)
# EXTRACT_URL_SUBPROCESS=true

# Link “Mini Apps” in header back to dashboard (port 3000 in dev)
# NEXT_PUBLIC_MINI_APPS_DASHBOARD_URL=http://localhost:3000/dashboard

# Redis (optional; if not set, pipeline runs inline and may timeout on serverless)
REDIS_URL=redis://localhost:6379
# If REDIS_URL is set but you don’t run `npm run worker`, briefings never finish — either run the worker or:
# BRIEFING_USE_QUEUE=false
# Absolute path to folder containing html-extract-worker.cjs (if cwd isn’t ai-news-briefing)
# EXTRACT_SCRAPER_DIR=/path/to/ai-news-briefing/src/lib/scraper

# Multilingual briefing (Hindi, Marathi, Punjabi, Bengali, Haryanvi-as-dialect)
# User picks language in UI; Azure voices below apply when Microsoft is used (recommended for Indic).
# Haryanvi reuses Hindi voices; dialogue is dialectal in Devanagari.
# AZURE_VOICE_HI_MALE=hi-IN-MadhurNeural
# AZURE_VOICE_HI_FEMALE=hi-IN-SwaraNeural
# AZURE_VOICE_MR_MALE=mr-IN-ManoharNeural
# AZURE_VOICE_MR_FEMALE=mr-IN-AarohiNeural
# AZURE_VOICE_PA_MALE=pa-IN-OjasNeural
# AZURE_VOICE_PA_FEMALE=pa-IN-VaaniNeural
# If pa-IN voices are missing in your Azure region, the app falls back to Hindi neural for the same script.
# AZURE_VOICE_BN_MALE=bn-IN-BashkarNeural
# AZURE_VOICE_BN_FEMALE=bn-IN-TanishaaNeural
