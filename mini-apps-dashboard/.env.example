# URL where AI News Briefing runs (dashboard embeds this in an iframe)
# Dashboard default dev port: 3000 | Briefing default dev port: 3001
NEXT_PUBLIC_AI_NEWS_BRIEFING_URL=http://localhost:3001

# NewsAPI.org — 32-char hex from https://newsapi.org/account (after Register / login).
# Must NOT be a UUID. Briefing app also reads this file when you run dev:all.
# NEWS_API_KEY=

# Server-side proxy for Figma news feed / history (optional; falls back to NEXT_PUBLIC_*)
# AI_NEWS_BRIEFING_URL=http://localhost:3001
