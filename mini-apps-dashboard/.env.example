# AI News Briefing is served at /briefing (same app). Override only if hosted elsewhere:
# NEXT_PUBLIC_AI_NEWS_BRIEFING_URL=https://other-host.com

# NewsAPI.org — 32-char hex from https://newsapi.org/account
# NEWS_API_KEY=
#
# Precedence: in development, the first `NEWS_API_KEY` found in `.env.local` (on disk)
# wins over stale `process.env` from when `next dev` started. In production, host/Vercel
# env wins, then file fallback. Use one active `NEWS_API_KEY=...` line (comment old keys).
#
# On NewsAPI 429, the app falls back to Google News RSS (no key). Disable with:
# NEWS_RSS_FALLBACK=0
# Cache identical /everything responses (ms). Default 600000 (10m). Disable: NEWS_API_CACHE_MS=0
# After 429, skip NewsAPI for this many ms (default 20m). Disable: NEWS_API_COOLDOWN_MS=0

# Optional: OpenAI, ElevenLabs, Azure Speech, Supabase, Redis — see ai-news-briefing/.env.example
