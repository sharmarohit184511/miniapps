# AI News Briefing is served at /briefing (same app). Override only if hosted elsewhere:
# NEXT_PUBLIC_AI_NEWS_BRIEFING_URL=https://other-host.com
# Dev-only (briefing on another port): http://localhost:3001 — OK locally; on Render leave unset
# or use your public URL. Server-side feed ignores loopback here and uses RENDER_EXTERNAL_URL instead.
# Split backend (server fetch): AI_NEWS_BRIEFING_URL=https://your-briefing-service.onrender.com
#
# Render / reverse proxies: server routes must call your *public* URL, not localhost:PORT.
# Render sets RENDER_EXTERNAL_URL automatically — ensure your Web Service has it (default).
# Optional manual public origin if needed: NEXT_PUBLIC_APP_URL=https://your-service.onrender.com

# NewsAPI.org — 32-char hex from https://newsapi.org/account
# NEWS_API_KEY=
#
# Precedence: in development, the first `NEWS_API_KEY` found in `.env.local` (on disk)
# wins over stale `process.env` from when `next dev` started. In production, host/Vercel
# env wins, then file fallback. Use one active `NEWS_API_KEY=...` line (comment old keys).
#
# On NewsAPI 429, the app falls back to Google News RSS (no key). Disable with:
# NEWS_RSS_FALLBACK=0
# Cache identical /everything responses (ms). Default 600000 (10m). Disable: NEWS_API_CACHE_MS=0
# After 429, skip NewsAPI for this many ms for THAT KEY only (default 20m). Disable: NEWS_API_COOLDOWN_MS=0
# Debug which file/env supplied the key: NEWS_API_DEBUG=1
#
# Monorepo: `mini-apps-dashboard/.env.local` is read before `ai-news-briefing/.env.local`.
# If you use multiple NEWS_API_KEY= lines in one file, the LAST one wins.

# --- URL extraction (briefing pipeline) — tune on Render if multi-source digests feel slow ---
# Max wall time per URL (ms). Default 85000; clamped 35000–180000. With 6+ sources, capped at 45000 unless you lower below that via env.
# EXTRACT_PER_URL_TIMEOUT_MS=60000
# Initial HTTP body fetch timeout (ms). Default 22000.
# EXTRACT_FETCH_BODY_TIMEOUT_MS=22000
# Mercury reader timeout (ms). Default 24000.
# EXTRACT_MERCURY_TIMEOUT_MS=24000
# Render free tier: cold starts can return HTML from the edge before Node runs — use retry in the app, upgrade to always-on, or accept occasional flakes.

# Optional: OpenAI, ElevenLabs, Azure Speech, Supabase, Redis — see ai-news-briefing/.env.example
