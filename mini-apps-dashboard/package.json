{
  "name": "mini-apps-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:queue": "concurrently -k -n dashboard,worker -c blue,green \"next dev -p 3000\" \"npm run worker\"",
    "dev:127": "next dev -p 3000 -H 127.0.0.1",
    "build": "next build",
    "postbuild": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "worker": "npx tsx src/workers/briefing-worker.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@mozilla/readability": "^0.6.0",
    "@postlight/mercury-parser": "^2.2.1",
    "@supabase/supabase-js": "^2.99.2",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "openai": "^6.31.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
